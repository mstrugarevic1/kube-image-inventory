# Kubernetes Image Inventory Configuration

# Database URL (SQLite)
DATABASE_URL=sqlite:///./inventory.db

# --- Kubernetes access -------------------------------------------------------

# Access mode: "auto" (default), "incluster", or "multicontext".
#   auto         - prefer in-cluster credentials, else use CLUSTERS_CONFIG_PATH
#                  if it exists, else fall back to the local kubeconfig's
#                  current-context (requires KUBE_IMAGE_INVENTORY_DEV_KUBECONFIG).
#   incluster    - always use the in-cluster ServiceAccount, represented as one
#                  configured cluster (see INCLUSTER_CLUSTER_* below).
#   multicontext - always load the explicit cluster list from
#                  CLUSTERS_CONFIG_PATH; fails startup if it is missing/invalid.
KUBE_ACCESS_MODE=auto

# Optional path to a kubeconfig file. Leave empty to use the client library
# default (the KUBECONFIG env var, or ~/.kube/config).
KUBECONFIG_PATH=

# Path to the explicit multi-cluster configuration file (see
# config/clusters.example.yaml).
CLUSTERS_CONFIG_PATH=./config/clusters.yaml

# A cluster is shown as "stale" if its last successful scan is older than this.
CLUSTER_STALE_AFTER_SECONDS=1800

# Identity used to represent the current cluster when KUBE_ACCESS_MODE=incluster
# (or when auto mode falls back to in-cluster credentials).
INCLUSTER_CLUSTER_ID=local-cluster
INCLUSTER_CLUSTER_NAME=Local Cluster
INCLUSTER_CLUSTER_ENVIRONMENT=local

# Enable local kubeconfig fallback for development when no cluster config file
# exists and in-cluster credentials are unavailable. Set to 'true' if running
# outside a cluster without a config/clusters.yaml file.
KUBE_IMAGE_INVENTORY_DEV_KUBECONFIG=false

# --- Scan ---------------------------------------------------------------------

# Background scan interval in seconds
SCAN_INTERVAL_SECONDS=900
